class Bank:

    def __init__(self):
        self.balance=10000
        self.pin=1234

    def withdraw(self,pin,amount):

        if pin==self.pin and amount<=self.balance:
            self.balance-=amount
            print("Balance =",self.balance)
        else:
            print("Transaction Failed")

b=Bank()

b.withdraw(1234,2000)
Output
Balance = 8000
