class BubbleSort:

    def sort(self, arr):

        for i in range(len(arr)):
            for j in range(len(arr)-i-1):
                if arr[j] > arr[j+1]:
                    arr[j], arr[j+1] = arr[j+1], arr[j]

        print(arr)

obj = BubbleSort()

obj.sort([5,2,8,1,3])
Output
[1, 2, 3, 5, 8]
