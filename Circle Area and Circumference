class Circle:

    def __init__(self, radius):
        self.radius = radius

    def area(self):
        print("Area =", 3.14 * self.radius ** 2)

    def circumference(self):
        print("Circumference =", 2 * 3.14 * self.radius)

c = Circle(5)

c.area()
c.circumference()
Output
Area = 78.5
Circumference = 31.4
